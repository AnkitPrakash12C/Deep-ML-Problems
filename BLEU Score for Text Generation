import numpy as np
from collections import Counter

def bleu_score(candidate: list[str], references: list[list[str]], max_n: int = 4) -> float:
    """
    Calculate BLEU score for a candidate sentence against reference sentences.
    
    Args:
        candidate: List of tokens in the candidate sentence
        references: List of reference sentences, each as a list of tokens
        max_n: Maximum n-gram order (default: 4)
    
    Returns:
        BLEU score between 0 and 1
    """
    # Your code here


    if not candidate:
        return 0.0

    c_len = len(candidate)

    ref_lens = [len(ref) for ref in references]
    r_len = min(ref_lens, key=lambda r: (abs(r - c_len), r))

    precisions = []

    for n in range(1, max_n + 1):

        cand_ngrams = [
            tuple(candidate[i:i+n])
            for i in range(len(candidate) - n + 1)
        ]

        if len(cand_ngrams) == 0:
            return 0.0

        cand_counts = Counter(cand_ngrams)

        max_ref_counts = Counter()

        for ref in references:
            ref_ngrams = [
                tuple(ref[i:i+n])
                for i in range(len(ref) - n + 1)
            ]

            ref_counts = Counter(ref_ngrams)

            for gram in ref_counts:
                max_ref_counts[gram] = max(
                    max_ref_counts[gram],
                    ref_counts[gram]
                )

        clipped_count = 0

        for gram in cand_counts:
            clipped_count += min(
                cand_counts[gram],
                max_ref_counts.get(gram, 0)
            )

        precision = clipped_count / sum(cand_counts.values())

        if precision == 0:
            return 0.0

        precisions.append(precision)

    log_precisions = sum(np.log(p) for p in precisions) / max_n
    geo_mean = np.exp(log_precisions)

    if c_len > r_len:
        bp = 1.0
    else:
        bp = np.exp(1 - (r_len / c_len))

    bleu = bp * geo_mean

    return float(bleu)
