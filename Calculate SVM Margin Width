import numpy as np

def svm_margin_width(w: np.ndarray) -> float:
    """
    Calculate the margin width of a linear SVM classifier.
    
    Parameters:
    w : np.ndarray - weight vector defining the hyperplane
    
    Returns:
    float - the total margin width
    """
    root = 0
    for i in range(len(w)):
        root = root + (w[i])**2

    ans = root**0.5
    return 2/ans
