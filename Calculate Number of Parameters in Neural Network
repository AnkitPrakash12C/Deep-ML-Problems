def count_parameters(layers: list) -> int:
    """
    Count the total number of trainable parameters in a neural network.
    
    Args:
        layers: A list of dictionaries describing each layer.
                Each dict contains 'type' and layer-specific parameters.
    
    Returns:
        Total number of trainable parameters as an integer.
    """
    # Your code here
    total_params = 0

    for layer in layers:
        layer_type = layer["type"].lower()

        if layer_type == "dense":
            params = layer["input_size"] * layer["output_size"]
            if layer.get("use_bias", True):
                params += layer["output_size"]
            total_params += params

        elif layer_type == "conv2d":
            kernel_size = layer["kernel_size"]

            if isinstance(kernel_size, int):
                kh, kw = kernel_size, kernel_size
            else:
                kh, kw = kernel_size

            params = (
                layer["out_channels"]
                * layer["in_channels"]
                * kh
                * kw
            )

            if layer.get("use_bias", True):
                params += layer["out_channels"]

            total_params += params

        elif layer_type == "embedding":
            params = (
                layer["num_embeddings"]
                * layer["embedding_dim"]
            )
            total_params += params

    return total_params
    pass
