import numpy as np

def distillation_loss(
    student_logits: np.ndarray,
    teacher_logits: np.ndarray,
    temperature: float = 1.0
) -> float:
    """
    Compute knowledge distillation loss using KL Divergence.
    L = T^2 * KL(softmax(teacher/T) || softmax(student/T))
    """
    s_soft = student_logits / temperature
    t_soft = teacher_logits / temperature

    exp_t = np.exp(t_soft - np.max(t_soft))
    p_teacher = exp_t / np.sum(exp_t)

    log_p_student = s_soft - np.max(s_soft)
    log_p_student -= np.log(np.sum(np.exp(log_p_student)))

    log_p_teacher = np.log(p_teacher + 1e-12)
    kl_div = np.sum(p_teacher * (log_p_teacher - log_p_student))

    return float(kl_div * (temperature ** 2))
