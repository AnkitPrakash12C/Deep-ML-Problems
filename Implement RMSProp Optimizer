import numpy as np

def rmsprop_update(params, grads, cache, lr=0.001, beta=0.9, epsilon=1e-8):
    """
    Perform one RMSProp update step.
    
    Args:
        params (list or np.ndarray): Current parameter values
        grads (list or np.ndarray): Gradients of parameters
        cache (list or np.ndarray): Running average of squared gradients
        lr (float): Learning rate
        beta (float): Decay rate for moving average
        epsilon (float): Small constant for numerical stability
        
    Returns:
        (updated_params, updated_cache)
    """
    
    params = np.array(params, dtype=np.float64)
    grads = np.array(grads, dtype=np.float64)
    cache = np.array(cache, dtype=np.float64)
    
    new_cache = beta * cache + (1 - beta) * (grads ** 2)
    
    new_params = params - lr * grads / (np.sqrt(new_cache) + epsilon)
    
    return np.round(new_params, 6).tolist(), np.round(new_cache, 6).tolist()
