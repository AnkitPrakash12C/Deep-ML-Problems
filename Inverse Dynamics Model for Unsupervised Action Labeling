import numpy as np

def inverse_dynamics_label(labeled_states: np.ndarray, labeled_next_states: np.ndarray, labeled_actions: np.ndarray, unlabeled_states: np.ndarray, unlabeled_next_states: np.ndarray, num_actions: int) -> list:
    """Fit a linear inverse dynamics model on labeled transitions and
    return predicted action labels for the unlabeled transitions.

    Args:
        labeled_states: array of shape (N, d) - states s_t for labeled data
        labeled_next_states: array of shape (N, d) - next states s_{t+1}
        labeled_actions: array of shape (N,) - integer action labels
        unlabeled_states: array of shape (M, d)
        unlabeled_next_states: array of shape (M, d)
        num_actions: number of discrete actions K

    Returns:
        List of M predicted integer action labels.
    """

    labeled_states = np.asarray(labeled_states, dtype=float)
    labeled_next_states = np.asarray(labeled_next_states, dtype=float)
    labeled_actions = np.asarray(labeled_actions, dtype=int)

    unlabeled_states = np.asarray(unlabeled_states, dtype=float)
    unlabeled_next_states = np.asarray(unlabeled_next_states, dtype=float)

    labeled_delta = labeled_next_states - labeled_states

    X = np.concatenate(
        [labeled_delta, np.ones((labeled_delta.shape[0], 1))],
        axis=1
    )

    Y = np.zeros((len(labeled_actions), num_actions))

    for i, a in enumerate(labeled_actions):
        Y[i, a] = 1.0

    W = np.linalg.pinv(X) @ Y

    unlabeled_delta = unlabeled_next_states - unlabeled_states

    X_test = np.concatenate(
        [unlabeled_delta, np.ones((unlabeled_delta.shape[0], 1))],
        axis=1
    )

    scores = X_test @ W

    predictions = np.argmax(scores, axis=1)

    return predictions.tolist()

