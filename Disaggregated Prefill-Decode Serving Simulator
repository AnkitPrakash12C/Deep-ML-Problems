import numpy as np

def disaggregated_serving_sim(requests, num_prefill, num_decode, prefill_rate, decode_rate, kv_transfer_rate):
	"""
	Simulate disaggregated prefill-decode LLM serving.
	
	Args:
		requests: List of dicts with 'arrival_time', 'prompt_tokens', 'output_tokens'
		num_prefill: Number of prefill GPU instances
		num_decode: Number of decode GPU instances
		prefill_rate: Tokens/second per prefill instance
		decode_rate: Tokens/second per decode instance
		kv_transfer_rate: Seconds per prompt token for KV cache transfer
	
	Returns:
		Dict with 'avg_ttft', 'avg_total_latency', 'throughput',
		     'prefill_utilization', 'decode_utilization'
	"""

    requests = sorted(requests, key=lambda x: x['arrival_time'])
    
    prefill_free = [0.0] * num_prefill
    decode_free = [0.0] * num_decode
    
    total_ttft = 0.0
    total_latency = 0.0
    total_output_tokens = 0
    
    total_prefill_busy = 0.0
    total_decode_busy = 0.0
    
    earliest_arrival = requests[0]['arrival_time'] if requests else 0.0
    last_completion = 0.0
    
    for req in requests:
        arrival = req['arrival_time']
        prompt_tokens = req['prompt_tokens']
        output_tokens = req['output_tokens']
        

        p_idx = min(range(num_prefill), key=lambda i: (prefill_free[i], i))
        p_start = max(arrival, prefill_free[p_idx])
        p_time = prompt_tokens / prefill_rate
        p_end = p_start + p_time
        
        prefill_free[p_idx] = p_end
        total_prefill_busy += p_time
        
        kv_time = prompt_tokens * kv_transfer_rate
        kv_end = p_end + kv_time
        
        d_idx = min(range(num_decode), key=lambda i: (decode_free[i], i))
        d_start = max(kv_end, decode_free[d_idx])
        d_time = output_tokens / decode_rate
        d_end = d_start + d_time
        
        decode_free[d_idx] = d_end
        total_decode_busy += d_time
        
        ttft = d_start - arrival
        latency = d_end - arrival
        
        total_ttft += ttft
        total_latency += latency
        total_output_tokens += output_tokens
        
        last_completion = max(last_completion, d_end)
    
    if not requests:
        return {
            'avg_ttft': 0.0,
            'avg_total_latency': 0.0,
            'throughput': 0.0,
            'prefill_utilization': 0.0,
            'decode_utilization': 0.0
        }
    
    makespan = last_completion - earliest_arrival
    
    avg_ttft = total_ttft / len(requests)
    avg_latency = total_latency / len(requests)
    throughput = total_output_tokens / makespan if makespan > 0 else 0.0
    
    prefill_util = total_prefill_busy / (num_prefill * makespan) if makespan > 0 else 0.0
    decode_util = total_decode_busy / (num_decode * makespan) if makespan > 0 else 0.0
    
    return {
        'avg_ttft': round(avg_ttft, 4),
        'avg_total_latency': round(avg_latency, 4),
        'throughput': round(throughput, 4),
        'prefill_utilization': round(prefill_util, 4),
        'decode_utilization': round(decode_util, 4)
    }
	pass
