import numpy as np

def compute_cross_entropy_loss(predicted_probs: np.ndarray, true_labels: np.ndarray, epsilon = 1e-15) -> float:
    # Your code here
    predicted_probs = np.array(predicted_probs, dtype=np.float64)
    true_labels = np.array(true_labels, dtype=np.float64)

    predicted_probs = np.clip(predicted_probs, epsilon, 1.0 - epsilon)

    log_probs = np.log(predicted_probs)
    loss = -np.sum(true_labels * log_probs) / predicted_probs.shape[0]

    return round(float(loss), 4)
