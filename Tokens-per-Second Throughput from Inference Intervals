def compute_throughput(intervals):
    """
    Compute step-wise, cumulative, and overall tokens-per-second.

    Args:
        intervals: list of (tokens_processed, elapsed_seconds) tuples.

    Returns:
        dict with keys 'step_tps', 'cumulative_tps', 'overall_tps'.
    """
    if not intervals:
        return {
            'step_tps': [],
            'cumulative_tps': [],
            'overall_tps': 0.0
        }

    step_tps = []
    cumulative_tps = []

    total_tokens = 0
    total_time = 0.0

    for tokens, elapsed in intervals:
        if tokens < 0:
            raise ValueError("tokens_processed cannot be negative")
        if elapsed <= 0:
            raise ValueError("elapsed_seconds must be positive")

        step = tokens / elapsed
        step_tps.append(round(step, 2))

        total_tokens += tokens
        total_time += elapsed

        cumulative = total_tokens / total_time
        cumulative_tps.append(round(cumulative, 2))

    overall_tps = round(total_tokens / total_time, 2)

    return {
        'step_tps': step_tps,
        'cumulative_tps': cumulative_tps,
        'overall_tps': overall_tps
    }
    pass
