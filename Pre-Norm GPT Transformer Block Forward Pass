import numpy as np

def pre_norm_transformer_block(x, params, num_heads):
    """
    Pre-norm Transformer block forward pass.

    Args:
        x: numpy array of shape (batch, seq_len, emb_dim)
        params: dict with keys 'ln1_gamma','ln1_beta','ln2_gamma','ln2_beta',
                'W_q','W_k','W_v','W_o','W_ff1','b_ff1','W_ff2','b_ff2'
        num_heads: int, number of attention heads (emb_dim must be divisible by num_heads)

    Returns:
        numpy array of shape (batch, seq_len, emb_dim)
    """

    def layer_norm(inp, gamma, beta, eps=1e-5):
        mean = np.mean(inp, axis=-1, keepdims=True)
        var = np.var(inp, axis=-1, keepdims=True)
        normed = (inp - mean) / np.sqrt(var + eps)
        return gamma * normed + beta

    def gelu(z):
        return 0.5 * z * (
            1 + np.tanh(
                np.sqrt(2 / np.pi) * (z + 0.044715 * (z ** 3))
            )
        )

    batch, seq_len, emb_dim = x.shape
    d_head = emb_dim // num_heads

    h = layer_norm(
        x,
        params["ln1_gamma"],
        params["ln1_beta"]
    )

    Q = h @ params["W_q"]
    K = h @ params["W_k"]
    V = h @ params["W_v"]

    Q = Q.reshape(batch, seq_len, num_heads, d_head).transpose(0,2,1,3)
    K = K.reshape(batch, seq_len, num_heads, d_head).transpose(0,2,1,3)
    V = V.reshape(batch, seq_len, num_heads, d_head).transpose(0,2,1,3)

    scores = np.matmul(Q, K.transpose(0,1,3,2))
    scores = scores / np.sqrt(d_head)

    mask = np.triu(np.ones((seq_len, seq_len)), k=1).astype(bool)
    scores = np.where(mask, -1e9, scores)

    scores = np.exp(scores - np.max(scores, axis=-1, keepdims=True))
    attn = scores / np.sum(scores, axis=-1, keepdims=True)

    context = np.matmul(attn, V)

    context = (
        context.transpose(0,2,1,3)
        .reshape(batch, seq_len, emb_dim)
    )

    attn_out = context @ params["W_o"]

    x = x + attn_out       

    h = layer_norm(
        x,
        params["ln2_gamma"],
        params["ln2_beta"]
    )

    ff = h @ params["W_ff1"] + params["b_ff1"]
    ff = gelu(ff)
    ff = ff @ params["W_ff2"] + params["b_ff2"]

    x = x + ff           

    return x
